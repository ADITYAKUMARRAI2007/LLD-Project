        <mxCell id="rel_factory_ballpen" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#000000;endArrow=open;startArrow=none;endFill=0;dashed=1;" parent="1" source="class_factory" target="class_ballpen" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- PenFactory creates GelPen -->
        <mxCell id="rel_factory_gelpen" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#000000;endArrow=open;startArrow=none;endFill=0;dashed=1;" parent="1" source="class_factory" target="class_gelpen" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- PenFactory uses WritingStrategy -->
        <mxCell id="rel_factory_strategy" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#000000;endArrow=open;startArrow=none;endFill=0;dashed=1;" parent="1" source="class_factory" target="interface_strategy" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Legend/Notes -->
        <mxCell id="legend_box" value="Key Relationships&#xa;━━━━━━━━━━━━━━━━━━━━━━━━&#xa;―――→  Inheritance (extends)&#xa;- - -→  Implementation (implements)&#xa;◇―――  Composition (contains)&#xa;◁―――  Aggregation (uses)&#xa;- - - →  Dependency / Creation" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#CCCCCC;fillColor=#F5F5F5;fontSize=10;align=left;" parent="1" vertex="1">
          <mxGeometry x="50" y="750" width="220" height="100" as="geometry" />
        </mxCell>

      </root>
